{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai.schema.json",
  "type": "object",
  "required": ["attributes"],
  "properties": {
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "score"],
        "properties": {
          "value": {},
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
